{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_URL": "http://192.168.1.8:8000/"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "API_URL": "https://REPLACE-WITH-YOUR-API-DOMAIN/"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
